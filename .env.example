# Database
POSTGRES_DB=nectar
POSTGRES_USER=nectar
POSTGRES_PASSWORD=changeme

# Server
NECTAR__DATABASE_URL=postgres://nectar:changeme@localhost:5432/nectar
NECTAR__JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
NECTAR__JWT_EXPIRY_HOURS=24
NECTAR__NATS_URL=nats://localhost:4222
NECTAR__HOST=0.0.0.0
NECTAR__PORT=8096
NECTAR__MEDIA_PATHS=/path/to/movies,/path/to/tv
NECTAR__TRANSCODE_OUTPUT_DIR=/tmp/nectar-transcode

# OIDC (optional)
# NECTAR__OIDC__ISSUER_URL=https://auth.example.com
# NECTAR__OIDC__CLIENT_ID=nectar
# NECTAR__OIDC__CLIENT_SECRET=secret

# Transcoder
NECTAR_TRANSCODER__NATS_URL=nats://localhost:4222
NECTAR_TRANSCODER__FFMPEG_PATH=ffmpeg
NECTAR_TRANSCODER__WORK_DIR=/tmp/nectar-transcode
NECTAR_TRANSCODER__MAX_CONCURRENT_JOBS=2

# Embeddings (optional — pick one)
# NECTAR__EMBEDDING_PROVIDER=ollama
# NECTAR__OLLAMA_URL=http://localhost:11434
# NECTAR__OLLAMA_MODEL=nomic-embed-text
# NECTAR__OPENAI_API_KEY=sk-...
# NECTAR__OPENAI_MODEL=text-embedding-3-small

# Media path for Docker
MEDIA_PATH=/path/to/media
