FROM rust:1.85-bookworm AS builder
WORKDIR /app
COPY Cargo.toml Cargo.lock* ./
COPY server/ server/
COPY transcoder/ transcoder/
RUN cargo build --release --package nectar-transcoder

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates ffmpeg && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/nectar-transcoder /usr/local/bin/
CMD ["nectar-transcoder"]
